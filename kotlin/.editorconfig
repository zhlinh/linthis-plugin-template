# EditorConfig for linthis-plugin-template Plugin (Kotlin)

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.kt]
indent_style = space
indent_size = 4
continuation_indent_size = 4
max_line_length = 120

[*.kts]
indent_style = space
indent_size = 4
